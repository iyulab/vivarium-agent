{
  "name": "@vivariumjs/agent",
  "version": "0.1.0",
  "description": "Agent harness that turns natural-language intent and on-screen selection into verified changesets — pluggable model provider, knowledge, and strategy. Output is a changeset or nothing.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iyulab/vivarium-agent.git"
  },
  "homepage": "https://github.com/iyulab/vivarium-agent#readme",
  "bugs": "https://github.com/iyulab/vivarium-agent/issues",
  "keywords": [
    "vivarium",
    "changeset",
    "agent",
    "llm",
    "ai-generated-ui"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "node --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@vivariumjs/changeset": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
